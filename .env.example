# Supabase（supabase/README.md 参照）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（クライアントに露出させない）
SUPABASE_SERVICE_ROLE_KEY=

# AI履歴書読み取り（Phase 7）
ANTHROPIC_API_KEY=

# 履歴書ツールの自由記述翻訳API（/api/translate・要件⑥）
# 有料APIを呼ぶため既定は無効。運用者が明示的に有効化し、許可オリジンを指定する。
ENABLE_TRANSLATE_API=false
# 呼び出しを許可するオリジン（カンマ区切り・ワイルドカード不可）
TRANSLATE_ALLOWED_ORIGINS=https://akina12231988-star.github.io
# 任意: 設定すると x-translate-token ヘッダ一致を必須にする
TRANSLATE_SHARED_TOKEN=
